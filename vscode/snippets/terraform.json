{
	"variable": {
			"prefix": "tfv",
			"description": "Define variables with default",
			"body": [
					"variable \"${1}\" {",
						"   description =   \"$2\"",
						"   default     =   \"$3\"",
					"}"
			]
	},
	"resource": {
		"prefix": "tfr",
		"description": "define a provisioner.",
		"body": [
				"resource \"${1}\" \"${2}\" {",
				"\t${3}",
				"}"
		]
	},
	"data": {
		"prefix": "tfd",
		"description": "define a data source.",
		"body": [
				"data \"${1}\" \"${2}\" {",
				"\t${3}",
				"}"
		]
	},
	"depends_on": {
			"prefix": "tfdep",
			"description": "Define explicit dependencies.",
			"body": [
					"depends_on = [\"${1}\"]"
			]
	}
}